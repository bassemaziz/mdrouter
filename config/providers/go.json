{
  "providers": {
    "go": {
      "type": "openai_compat",
      "base_url": "https://opencode.ai/zen/go/v1",
      "api_key_env": "OPENCODE_GO_API_KEY",
      "headers": {
        "User-Agent": "opencode"
      },
      "wire_format": "openai_chat",
      "timeout": 90,
      "quirks": [
        "require_reasoning_content_for_tool_calls",
        "normalize_multimodal_content"
      ]
    }
  },
