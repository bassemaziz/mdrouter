      }
    },
    "zen/gpt-5-nano": {
      "provider": "zen",
      "upstream_model": "gpt-5-nano",
      "capabilities": ["chat", "stream", "tools"],
      "context_length": 272000,
      "extra": {
        "tier": "free"
      }
    }
  }
}
